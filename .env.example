# Runtime
NODE_ENV=development                   # development | production | test
PORT=7860                              # HTTP listener port
API_VERSION=2.0.0                      # Reported by /api/status
TRUST_PROXY=1                          # Number of proxy hops Express should trust
BODY_LIMIT_MB=1                        # JSON/urlencoded body cap (multipart bypasses this)

# Browser automation
CHROME_BIN=/usr/bin/chromium           # Playwright executablePath

# Upstream integrations (all optional — endpoints return 400/502 when unset)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"               # /api/promosi
DISCORD_WEBHOOK_URL="YOUR_DISCORD_WEBHOOK_URL"     # /api/miq avatar upload
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"       # /api/telegram
YOUTUBE_COOKIES_B64=                                # Base64-encoded cookies.txt for YouTube
YOUTUBE_PLAYER_CLIENT=                              # OPT-IN. Empty = use built-in fallback chain. Override with comma-list e.g. "tv_simply,web_safari".
YOUTUBE_PO_TOKEN=                                   # OPT-IN. yt-dlp PO Token for accounts under strict enforcement. Format: <client>+<token>

# Downloads cleanup
DOWNLOADS_TTL_MIN=60                                # Delete files in downloads/ older than N minutes (default 60).
DOWNLOADS_SWEEP_MIN=5                               # Sweep interval in minutes (default 5).

# API key auth
# Optional. If set, this plaintext key is registered as the master key on boot
# (it grants /api/admin/* access and bypasses rate limits). Leave empty to let
# the server auto-generate one on first run and print it to data/master-key.txt.
# Format: rex_<base64url 43 chars>
MASTER_API_KEY=

# JWT (user dashboard auth, separate from API key auth)
# Optional. If empty the server auto-generates a 64-byte secret on first boot
# and writes it to data/jwt-secret.txt — move it into env on the next deploy
# so all instances share the same signing key.
JWT_SECRET=
JWT_EXPIRES_IN=7d                       # 1h, 24h, 7d, 30d, ...
BCRYPT_ROUNDS=10                        # 8-14; 10 is the standard sweet spot

# Anti-spam burst limit (per-second cap per IP; applies to ALL tiers).
ANTI_SPAM_PER_SECOND=5

# Login brute-force guard (sliding window = 15 minutes; success doesn't count).
LOGIN_LIMIT_PER_IP=10
LOGIN_LIMIT_PER_IDENTIFIER=5

# Register throttle (sliding window = 1 hour). Failed attempts also count.
REGISTER_LIMIT_PER_IP=5

# Daily quota (1 hit = 1 unit, reset at local midnight). Master tier bypasses.
QUOTA_ANON_DAILY=30
QUOTA_USER_DAILY=250
QUOTA_FLUSH_INTERVAL_SEC=60

# Misc
FILE_IO_API_URL=https://tmpfiles.org   # Generic file hosting for transient uploads
BEDROCK_PREFIXES=.;*;bed:              # /mcapi — prefixes that identify Bedrock usernames
